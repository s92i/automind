<%- include('base', {
    title: 'Reset your password',
    subtitle: 'Secure access to your Automind account',
    body: `
      <h2>Hello ${name}! 👋</h2>
      <p>We received a request to reset the password for your Automind account.</p>
      <p>Click the button below to choose a new password:</p>
      <div style="text-align: center; margin: 30px 0;">
        <a href="${url}" class="button" style="color: #fff !important">Reset Password</a>
      </div>
      <div class="highlight">
        <p><strong>🔒 Security Note:</strong> This password reset link is time-sensitive and should only be used by you.</p>
      </div>
      <p>If the button doesn't work, you can also copy and paste this link into your browser:</p>
      <p style="word-break: break-all; background: #f3f4f6; padding: 15px; border-radius: 6px; font-family: monospace; font-size: 14px; color: #374151;">
        ${url}
      </p>
      <p>If you did not request a password reset, you can safely ignore this email.</p>
      <p>Best regards,<br>The Automind Team</p>
    `
  }) %>